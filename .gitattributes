# Set default behavior to automatically normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files to always have LF
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
